# =============================================================================
# Enterprise Platform - Local Lab (Vagrant + VMware Desktop)
# =============================================================================
# Creates VMs for the RKE2 cluster:
#   - master-01 (control plane) — always created
#   - worker-01 (agent)         — optional (EP_WORKERS=true)
#   - worker-02 (agent)         — optional (EP_WORKERS=true)
#
# Default: Single-node cluster (master-01 only).
# Multi-node: Set EP_WORKERS=true to create worker VMs.
#
# Usage:
#   vagrant up                              # Single-node (master-01 only)
#   EP_WORKERS=true vagrant up              # Multi-node (master + workers)
#   vagrant ssh master-01                   # SSH to master
#   vagrant destroy -f                      # Destroy all VMs
# =============================================================================

WORKERS = ENV['EP_WORKERS'] == 'true'

NODES = [
  {
    name: "ep-master-01",
    hostname: "master-01",
    ip: "192.168.56.10",
    cpus: 2,
    memory: 4096,
    role: "server"
  },
  {
    name: "ep-worker-01",
    hostname: "worker-01",
    ip: "192.168.56.11",
    cpus: 2,
    memory: 4096,
    role: "agent"
  },
  {
    name: "ep-worker-02",
    hostname: "worker-02",
    ip: "192.168.56.12",
    cpus: 2,
    memory: 4096,
    role: "agent"
  }
]

Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"
  config.vm.box_architecture = "amd64"

  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.provider "vmware_desktop" do |vmware|
    vmware.allowlist_verified = true
  end

  NODES.each do |node|
    next if node[:role] == 'agent' && !WORKERS

    config.vm.define node[:name] do |cfg|
      cfg.vm.hostname = node[:hostname]
      cfg.vm.network "private_network", ip: node[:ip]

      # Port forwarding for master node (ArgoCD UI + Ingress)
      if node[:name] == "ep-master-01"
        cfg.vm.network "forwarded_port", guest: 30080, host: 30080  # ArgoCD HTTP
        cfg.vm.network "forwarded_port", guest: 30443, host: 30443  # ArgoCD HTTPS
        cfg.vm.network "forwarded_port", guest: 80, host: 8080      # Ingress HTTP
        cfg.vm.network "forwarded_port", guest: 443, host: 8443     # Ingress HTTPS
      end

      cfg.vm.provider "vmware_desktop" do |vmware|
        vmware.vmx["memsize"] = node[:memory].to_s
        vmware.vmx["numvcpus"] = node[:cpus].to_s
        vmware.vmx["guestOS"] = "ubuntu-64"
        vmware.vmx["displayName"] = node[:name]
      end
      cfg.vm.provision "shell", path: "scripts/bootstrap.sh",
        args: [node[:role], node[:ip]]
    end
  end
end
