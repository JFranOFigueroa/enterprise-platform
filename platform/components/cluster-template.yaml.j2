# Enterprise Platform - Cluster Registration (Dynamic)
# Registers the target cluster in ArgoCD for the platform-apps ApplicationSet.
# Rendered by Ansible using target_environment as the cluster name.
#
# Used by gitops role when argocd_mode == "local" and cluster != dev-local.
# For dev-local, cluster-local.yaml is used directly (static, no rendering needed).
apiVersion: v1
kind: Secret
metadata:
  name: cluster-{{ target_environment }}
  namespace: gitops
  labels:
    argocd.argoproj.io/secret-type: cluster
type: Opaque
stringData:
  name: {{ target_environment }}
  server: https://kubernetes.default.svc
