# Parched by Ansible - DO NOT EDIT MANUALLY
# This Application injects real secrets via helm.parameters
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: iumbit
  namespace: gitops
spec:
  project: enterprise-platform
  source:
    repoURL: https://github.com/JFranOFigueroa/enterprise-platform.git
    targetRevision: main
    path: applications/iumbit
    helm:
      valueFiles:
        - values-dev.yaml
      parameters:
{% for key, value in iumbit_secrets.items() %}
        - name: "{{ key }}"
          value: "{{ value }}"
{% endfor %}
  destination:
    server: https://kubernetes.default.svc
    namespace: apps-dev
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
