      parameters:
{% for key, value in app_secrets.items() %}
        - name: "{{ key }}"
          value: "{{ value }}"
{% endfor %}
  destination:
    server: {{ app_config.cluster_server | default('https://kubernetes.default.svc') }}
    namespace: {{ app_config.namespace }}
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
