---
# Enterprise Platform - On-Premise / Production Credentials
# =============================================================================
# GITIGNORED - This file must NEVER be committed to Git.
#
# Setup:
#   cp secrets.yml.example secrets.yml
#   # Edit secrets.yml with your actual values
#
# run-ansible.sh loads this file automatically via --extra-vars "@secrets.yml"
# with the highest precedence (overrides all other variable sources).
# =============================================================================

# =============================================================================
# On-Premise Server Access (required for onprem inventories)
# =============================================================================
# These variables are used by inventory/onprem/hosts.yml and hosts-workers.yml.
# For hosts-local.yml (localhost mode), only onprem_master_node_ip is needed.

# SSH user for Ansible connections
onprem_user: ansible

# Master node: SSH hostname or IP (where Ansible connects)
onprem_master_host: "192.168.1.100"

# Master node: Internal IP (the node_ip that RKE2 will use for cluster communication)
onprem_master_node_ip: "192.168.1.100"

# Path to SSH private key (absolute or ~ expanded)
onprem_private_key: "~/.ssh/enterprise-platform"

# =============================================================================
# Worker Nodes (required only for multi-node with --workers flag)
# =============================================================================
# Uncomment and fill in for worker nodes.
#
# onprem_worker_01_host: "192.168.1.101"
# onprem_worker_01_node_ip: "192.168.1.101"
# onprem_worker_02_host: "192.168.1.102"
# onprem_worker_02_node_ip: "192.168.1.102"
